{%- comment -%}
  Site-wide structured data — Organization (every page) + WebSite search box (homepage).
  Replaces the removed EComposer `ecom_google_snippet`.
  Product JSON-LD is handled separately by snippets/product-jsonld.liquid.
{%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ shop.name | json }},
  "url": "https://{{ shop.domain }}",
  {%- if shop.phone != blank %}
  "telephone": {{ shop.phone | json }},
  {%- endif %}
  {%- if settings.logo != blank %}
  "logo": {{ settings.logo | image_url: width: 500 | prepend: 'https:' | json }},
  "image": {{ settings.logo | image_url: width: 500 | prepend: 'https:' | json }},
  {%- endif %}
  "description": {{ shop.description | json }}
}
</script>
{%- if request.page_type == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": {{ shop.name | json }},
  "url": "https://{{ shop.domain }}",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://{{ shop.domain }}/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}
</script>
{%- endif -%}
